{
  "name": "multi-env-demo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "webpack --config webpack.config.ts",
    "build:basic": "webpack --config webpack.config.ts --env edition=basic",
    "build:full": "webpack --config webpack.config.ts --env edition=full",
    "build:premium": "webpack --config webpack.config.ts --env edition=premium",
    "dev": "webpack serve --config webpack.config.ts --env edition=basic",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "html-webpack-plugin": "^5.6.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
